# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Your Anthropic API key (sk-ant-...)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Comma-separated list of valid access tokens for WASI users
# Generate random strings: e.g. WASI-XXXX-YYYY-ZZZZ
WASI_ACCESS_TOKENS=WASI-DEMO-2026,WASI-PRO-AAAA-BBBB

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-6

# Your GitHub Pages URL (no trailing slash)
ALLOWED_ORIGINS=https://atarawendesidkabore-hash.github.io

# Port (Render sets this automatically)
PORT=3000
