# WASI AI Proxy — environment variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Required: Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Optional: Claude model to use
CLAUDE_MODEL=claude-sonnet-4-5

# Optional: Comma-separated list of valid WASI access tokens
WASI_ACCESS_TOKENS=WASI-DEMO-DM01,WASI-PROD-TK01

# Optional: Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://atarawendesidkabore-hash.github.io,http://localhost:5500

# Optional: Port (Render sets this automatically)
PORT=3000
